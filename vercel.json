{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api(.*)",
      "dest": "index.js"
    },
    {
      "src": "/(.*\\.(css|js|jpg|png|ico|svg|gif|mp4|webp))",
      "dest": "/$1"
    },
    {
      "src": "/",
      "dest": "index.html"
    }
  ]
}
